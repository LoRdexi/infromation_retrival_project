# ==============================================================================
# || ملف .gitignore النهائي لمشروع نظام استرجاع المعلومات                   ||
# || هذا الملف يخبر Git بتجاهل الملفات والمجلدات غير الضرورية والخاصة.     ||
# ==============================================================================

# 1. البيئة الافتراضية (Virtual Environment)
#    يحتوي على آلاف الملفات الخاصة ببيئة بايثون على جهازك فقط.
#    يجب تجاهله دائماً.
/venv/
/env/
/.venv/
/ENV/

# 2. النماذج والفهارس (Models and Indexes)
#    هذا هو المجلد الأكبر حجماً، ويتم إنشاؤه تلقائياً بواسطة الخدمات.
#    لا يجب رفعه أبداً إلى المستودع.
/models_v2/

# 3. ملفات بايثون المؤقتة (Python Cache)
#    يتم إنشاؤها تلقائياً بواسطة بايثون لتسريع التنفيذ.
__pycache__/
*.pyc
*.pyo
*.pyd

# 4. ملفات السجلات (Log Files)
#    يتم إنشاؤها في كل مرة يتم فيها تشغيل الخدمات.
*.log

# 5. ملف الإعدادات الحساس (Sensitive Config)
#    ملف `config.py.example` يمثل قالب بدلاً منه.
config.py

# 6. ملفات Jupyter Notebook المؤقتة
#    يتم إنشاؤها تلقائياً عند العمل على الـ Notebooks.
.ipynb_checkpoints/

# 7. ملفات قواعد البيانات المحلية (إذا تم استخدامها)
*.sqlite
*.sqlite3
*.db

# 8. ملفات خاصة بأنظمة التشغيل (OS-specific files)
#    للحفاظ على نظافة المستودع بغض النظر عن نظام التشغيل.
.DS_Store
Thumbs.db

# 9. Generated evaluation charts (large PNG files)
evaluation_results_*.png

# 10. Representation build log
representation_build.log
